<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Jitsi Meet View (65% altura) -->
    <FrameLayout
        android:id="@+id/jitsiContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.65"
        app:layout_constraintTop_toTopOf="parent">
        
        <!-- JitsiMeetView será adicionado programaticamente aqui -->
        
        <!-- Overlay de Resultado de Dado -->
        <TextView
            android:id="@+id/tvDiceOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#AA000000"
            android:padding="16dp"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:visibility="gone" />

        <!-- Overlay de Timer -->
        <TextView
            android:id="@+id/tvTimerOverlay"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="@drawable/circle_background"
            android:gravity="center"
            android:textColor="@color/amber_highlight"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <!-- TabLayout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/jitsiContainer"
        app:tabIndicatorColor="@color/accent"
        app:tabSelectedTextColor="@color/accent"
        app:tabTextColor="@color/text_color">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dice_tab" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/character_sheet_tab" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/map_tab" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/soundboard_tab" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/initiative_tab" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Conteúdo da Aba (35% altura) -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout" />

</androidx.constraintlayout.widget.ConstraintLayout>
